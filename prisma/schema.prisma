// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider               = "prisma-client"
  output                 = "../src/generated/prisma"
  moduleFormat           = "cjs"
  generatedFileExtension = "ts"
}

generator json {
  provider = "prisma-json-types-generator"
}

datasource db {
  provider = "postgresql"
}

//////////////////////////////////////////
// ENUMS
//////////////////////////////////////////

enum OrderStatus {
  PENDING_CONFIRMATION
  PENDING_PICKUP
  PENDING_DELIVERY
  DELIVERED
  RETURNED
  CANCELLED
}

enum OtpCodeType {
  LOGIN
  REGISTER
  FORGOT_PASSWORD
  DISABLE_2FA
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum HTTPMethod {
  GET
  POST
  PUT
  DELETE
  PATCH
  OPTIONS
  HEAD
}

//////////////////////////////////////////
// CORE MODELS
//////////////////////////////////////////

model Language {
  /**
   * Tối ưu lại việc fetch data cho Language
   * Vấn đề: client browser muốn fetch được data của Language thì phải truyền "code" lên, sau đó server dựa vào "code" để query find Language, sau đó extract "id" từ Language để query data -> tốn 2 lần fetch.
   * Cách giải quyết:
   * Cách 1: cache lại bảng Language thì sẽ giảm 1 lần query -> rườm rà không cần thiết.
   * Cách 2: đổi trường "id" thành "code", nghĩa là bảng Language sẽ không còn "id" tự tăng nữa, muốn fetch thì phải truyền id unique. Qua đó, nếu dùng cách này thì sẽ giảm được 1 lần fetch và không phải cache.
   */
  id   String @id @unique @db.VarChar(10)
  name String @db.VarChar(500)

  // id   Int    @id @default(autoincrement())
  // name String @db.VarChar(500)
  // code String @unique @db.VarChar(10)

  createdById Int?
  updatedById Int?
  deletedById Int?

  createdBy User? @relation("LanguageCreatedBy", fields: [createdById], references: [id], onDelete: SetNull, onUpdate: NoAction)
  updatedBy User? @relation("LanguageUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull, onUpdate: NoAction)
  deletedBy User? @relation("LanguageDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull, onUpdate: NoAction)

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  userTranslations     UserTranslation[]
  productTranslations  ProductTranslation[]
  categoryTranslations CategoryTranslation[]
  brandTranslations    BrandTranslation[]

  @@index([deletedAt]) // mục đích index trường "deletedAt" để khi query các item là null (nghĩa là chưa xoá mềm) sẽ nhanh hơn.
}

model User {
  id          Int     @id @default(autoincrement())
  email       String // @unique // email cần set unique index với điều kiện deletedAt = null
  name        String  @db.VarChar(500)
  password    String  @db.VarChar(100)
  phoneNumber String? @db.VarChar(50) // optional vì user đăng ký/đăng nhập bằng tài khoản google không phải user nào cũng có phone number
  avatar      String? @db.VarChar(1000)

  totpSecret String?    @db.VarChar(1000) // field này có thể dùng để thực hiện chức năng quên mật khẩu, đăng nhập 2 bước
  status     UserStatus @default(ACTIVE)

  roleId Int
  role   Role @relation(fields: [roleId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  refreshTokens RefreshToken[]
  devices       Device[] // liên kết 1-n với Device
  carts         CartItem[]
  orders        Order[]
  reviews       Review[]

  createdPermissions          Permission[]          @relation("PermissionCreatedBy")
  updatedPermissions          Permission[]          @relation("PermissionUpdatedBy")
  deletedPermissions          Permission[]          @relation("PermissionDeletedBy")
  createdRoles                Role[]                @relation("RoleCreatedBy")
  updatedRoles                Role[]                @relation("RoleUpdatedBy")
  deletedRoles                Role[]                @relation("RoleDeletedBy")
  createdProducts             Product[]             @relation("ProductCreatedBy")
  updatedProducts             Product[]             @relation("ProductUpdatedBy")
  deletedProducts             Product[]             @relation("ProductDeletedBy")
  createdCategories           Category[]            @relation("CategoryCreatedBy")
  updatedCategories           Category[]            @relation("CategoryUpdatedBy")
  deletedCategories           Category[]            @relation("CategoryDeletedBy")
  createdSkus                 SKU[]                 @relation("SkuCreatedBy")
  updatedSkus                 SKU[]                 @relation("SkuUpdatedBy")
  deletedSkus                 SKU[]                 @relation("SkuDeletedBy")
  createdLanguages            Language[]            @relation("LanguageCreatedBy")
  updatedLanguages            Language[]            @relation("LanguageUpdatedBy")
  deletedLanguages            Language[]            @relation("LanguageDeletedBy")
  createdBrands               Brand[]               @relation("BrandCreatedBy")
  updatedBrands               Brand[]               @relation("BrandUpdatedBy")
  deletedBrands               Brand[]               @relation("BrandDeletedBy")
  createdProductTranslations  ProductTranslation[]  @relation("ProductTranslationCreatedBy")
  updatedProductTranslations  ProductTranslation[]  @relation("ProductTranslationUpdatedBy")
  deletedProductTranslations  ProductTranslation[]  @relation("ProductTranslationDeletedBy")
  createdCategoryTranslations CategoryTranslation[] @relation("CategoryTranslationCreatedBy")
  updatedCategoryTranslations CategoryTranslation[] @relation("CategoryTranslationUpdatedBy")
  deletedCategoryTranslations CategoryTranslation[] @relation("CategoryTranslationDeletedBy")
  createdBrandTranslations    BrandTranslation[]    @relation("BrandTranslationCreatedBy")
  updatedBrandTranslations    BrandTranslation[]    @relation("BrandTranslationUpdatedBy")
  deletedBrandTranslations    BrandTranslation[]    @relation("BrandTranslationDeletedBy")
  createdOrders               Order[]               @relation("OrderCreatedBy")
  updatedOrders               Order[]               @relation("OrderUpdatedBy")
  deletedOrders               Order[]               @relation("OrderDeletedBy")
  createdUserTranslations     UserTranslation[]     @relation("UserTranslationCreatedBy")
  updatedUserTranslations     UserTranslation[]     @relation("UserTranslationUpdatedBy")
  deletedUserTranslations     UserTranslation[]     @relation("UserTranslationDeletedBy")
  userTranslations            UserTranslation[]     @relation("User")
  sentMessages                Message[]             @relation("FromUser")
  receivedMessages            Message[]             @relation("ToUser")

  // 1 user có thể tạo ra nhiều user khác
  // 1 user chỉ có thể được tạo ra bởi 1 user khác
  // Tự quan hệ 1-n
  createdById Int?
  updatedById Int?
  deletedById Int?

  createdBy User? @relation("UserCreatedBy", fields: [createdById], references: [id], onDelete: SetNull, onUpdate: NoAction)
  updatedBy User? @relation("UserUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull, onUpdate: NoAction)
  deletedBy User? @relation("UserDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull, onUpdate: NoAction)

  createdUsers User[] @relation("UserCreatedBy")
  updatedUsers User[] @relation("UserUpdatedBy")
  deletedUsers User[] @relation("UserDeletedBy")

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([deletedAt]) // mục đích index trường "deletedAt" để khi query các item là null (nghĩa là chưa xoá mềm) sẽ nhanh hơn.
}

model UserTranslation {
  id          Int     @id @default(autoincrement())
  userId      Int
  languageId  String
  address     String? @db.VarChar(500)
  description String?

  createdById Int?
  updatedById Int?
  deletedById Int?

  user     User     @relation("User", fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  language Language @relation(fields: [languageId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  createdBy User? @relation("UserTranslationCreatedBy", fields: [createdById], references: [id], onDelete: SetNull, onUpdate: NoAction)
  updatedBy User? @relation("UserTranslationUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull, onUpdate: NoAction)
  deletedBy User? @relation("UserTranslationDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull, onUpdate: NoAction)

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([deletedAt]) // mục đích index trường "deletedAt" để khi query các item là null (nghĩa là chưa xoá mềm) sẽ nhanh hơn.
}

model OtpCode {
  id    Int         @id @default(autoincrement())
  email String      @db.VarChar(500)
  code  String      @db.VarChar(50)
  type  OtpCodeType // LOGIN: mã đăng nhập bằng 2FA, REGISTER: mã đăng ký, FORGOT_PASSWORD: mã quên mật khẩu, DISABLE_2FA: mã vô hiệu hóa 2FA

  expiresAt DateTime
  createdAt DateTime @default(now())

  @@unique([email, code, type]) // vì 1 otp sẽ có nhiều email trùng nhau nhưng code và type sẽ khác nhau nên sẽ không unique trường email mà sẽ unique 1 bộ [email, code, type]
  @@index([expiresAt]) // mục đích index trường này là sau này dùng cronjob để xóa các otp code đã hết hạn
}

model RefreshToken {
  token    String @unique @db.VarChar(1000)
  userId   Int
  deviceId Int // Foreign key to Device model

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt]) // mục đích index trường này là sau này dùng cronjob để xóa các refresh token đã hết hạn
}

model Device {
  id        Int     @id @default(autoincrement())
  userId    Int
  userAgent String
  ip        String
  isActive  Boolean @default(true) // Trạng thái thiết bị (đang login hay đã logout)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt    DateTime @default(now())
  lastActiveAt DateTime @updatedAt // updatedAt sửa lại thành lastActiveAt nếu muốn rõ ngữ nghĩa hơn

  refreshTokens RefreshToken[] // liên kết 1-n với RefreshToken
}

model Permission {
  id          Int        @id @default(autoincrement())
  name        String     @unique @db.VarChar(500)
  description String     @default("")
  path        String     @db.VarChar(1000)
  method      HTTPMethod
  module      String     @default("") @db.VarChar(500)

  createdById Int?
  updatedById Int?
  deletedById Int?

  createdBy User? @relation("PermissionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull, onUpdate: NoAction)
  updatedBy User? @relation("PermissionUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull, onUpdate: NoAction)
  deletedBy User? @relation("PermissionDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull, onUpdate: NoAction)

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  roles Role[] // PermissionsRoles[] - Implicit many-to-many (Prisma tự động tạo bảng _PermissionToRole)

  // CÁCH VIẾT EXPLICIT MANY-TO-MANY (nếu cần thêm fields vào bảng junction):
  // permissionsRoles PermissionsRoles[]

  // mong muốn path và method là unique theo cặp value ví dụ ("/api/v1/get-permissions", "GET") nghĩa là không thể có 2 records có cùng path và method.
  // nhưng hiện tại đang vướng 1 vấn đề khác là trường "deleteAt" chỉ xoá mềm, nghĩa là không thể xoá record đó mà chỉ có thể set deletedAt = now() để xoá mềm.
  // vì vậy không thể tạo 1 record mới có trùng path và method ("/api/v1/get-permissions", "GET").
  // nếu dùng "deleteAt" làm unique @@unique([path, method, deleteAt]) thì postgreSql vẫn cho tạo lại record mới có cùng path và method.
  // ví dụ: tạo 1 record mới có path = "/api/v1/get-permissions" và method = "GET" và deleteAt = null, sau đó tạo 1 record mới có path = "/api/v1/get-permissions" và method = "GET" và deleteAt = null thì postgreSql vẫn cho tạo lại.
  // vì trong postgreSql xem null là khác nhau nên => không unique => có thể tạo lại mới trùng method và path.
  // cách giải quyết: dùng kỹ thuật "Partial Unique Index" để tạo index cho cặp "path" và "method" nhưng với điều kiện "deleteAt = null".
  // ví dụ: @@unique([path, method], { where: { deleteAt: null } }) => không quan tâm deleteAt: now() => đã có giá trị => đã xoá mềm, chỉ quan tâm chưa xoá mềm là deleteAt = null.
  // @@unique([path, method], { where: { deletedAt: null } }) // Đã set trong SQL migration 20260127070521_permission_path_method_unique
  @@index([deletedAt]) // mục đích index trường "deletedAt" để khi query các item là null (nghĩa là chưa xoá mềm) sẽ nhanh hơn.
}

model Role {
  id          Int     @id @default(autoincrement())
  name        String  @db.VarChar(500)
  description String  @default("")
  isActive    Boolean @default(true)

  createdById Int?
  updatedById Int?
  deletedById Int?

  createdBy User? @relation("RoleCreatedBy", fields: [createdById], references: [id], onDelete: SetNull, onUpdate: NoAction)
  updatedBy User? @relation("RoleUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull, onUpdate: NoAction)
  deletedBy User? @relation("RoleDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull, onUpdate: NoAction)

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  users       User[]
  permissions Permission[] // PermissionsRoles[] - Implicit many-to-many (Prisma tự động tạo bảng _PermissionToRole)

  // CÁCH VIẾT EXPLICIT MANY-TO-MANY (nếu cần thêm fields vào bảng junction):
  // permissionsRoles PermissionsRoles[]

  // @@unique([name], { where: { deletedAt: null } }) // Đã set trong SQL migration 20260127125425_role_unique_name_default_description
  @@index([deletedAt]) // mục đích index trường "deletedAt" để khi query các item là null (nghĩa là chưa xoá mềm) sẽ nhanh hơn.
}

//////////////////////////////////////////
// PRODUCT DOMAIN
//////////////////////////////////////////

model Product {
  id           Int       @id @default(autoincrement())
  name         String    @db.VarChar(500)
  basePrice    Float
  virtualPrice Float
  brandId      Int
  images       String[]
  publishedAt  DateTime?
  /// [ProductVariantType]
  variants     Json // { value: string, options: string[] }[] => install prisma json type generator => declare type global => npx prisma generate type

  brand Brand @relation(fields: [brandId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  createdById Int
  updatedById Int?
  deletedById Int?

  createdBy User  @relation("ProductCreatedBy", fields: [createdById], references: [id], onDelete: Cascade, onUpdate: NoAction) // onDelete: Cascade => khi shop (user) bị xoá thì các product của shop đó cũng phải bị xoá
  updatedBy User? @relation("ProductUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull, onUpdate: NoAction)
  deletedBy User? @relation("ProductDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull, onUpdate: NoAction)

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  productTranslations ProductTranslation[]
  skus                SKU[]
  reviews             Review[]
  categories          Category[] // ProductsCategories[] - Implicit many-to-many (Prisma tự động tạo bảng _CategoryToProduct)
  orders              Order[] // ProductsOrders[] - Implicit many-to-many (Prisma tự động tạo bảng _ProductToOrder)

  // CÁCH VIẾT EXPLICIT MANY-TO-MANY (nếu cần thêm fields vào bảng junction):
  // productsCategories ProductsCategories[]

  @@index([deletedAt]) // mục đích index trường "deletedAt" để khi query các item là null (nghĩa là chưa xoá mềm) sẽ nhanh hơn.
}

model ProductTranslation {
  id          Int    @id @default(autoincrement())
  productId   Int
  languageId  String
  name        String @db.VarChar(500)
  description String

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  language Language @relation(fields: [languageId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  createdById Int?
  updatedById Int?
  deletedById Int?

  createdBy User? @relation("ProductTranslationCreatedBy", fields: [createdById], references: [id], onDelete: SetNull, onUpdate: NoAction)
  updatedBy User? @relation("ProductTranslationUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull, onUpdate: NoAction)
  deletedBy User? @relation("ProductTranslationDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull, onUpdate: NoAction)

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // @@unique([productId, languageId], { where: { deletedAt: null } }) // Đã set trong SQL migration 20260201070626_refactor_product
  @@index([deletedAt]) // mục đích index trường "deletedAt" để khi query các item là null (nghĩa là chưa xoá mềm) sẽ nhanh hơn.
}

model Category {
  id               Int     @id @default(autoincrement())
  name             String  @db.VarChar(500)
  logo             String? @db.VarChar(1000)
  parentCategoryId Int?

  parentCategory     Category?  @relation("CategoryParentCategories", fields: [parentCategoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  childrenCategories Category[] @relation("CategoryParentCategories")

  createdById Int?
  updatedById Int?
  deletedById Int?

  createdBy User? @relation("CategoryCreatedBy", fields: [createdById], references: [id], onDelete: SetNull, onUpdate: NoAction)
  updatedBy User? @relation("CategoryUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull, onUpdate: NoAction)
  deletedBy User? @relation("CategoryDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull, onUpdate: NoAction)

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  categoryTranslations CategoryTranslation[]
  products             Product[] // ProductsCategories[] - Implicit many-to-many (Prisma tự động tạo bảng _CategoryToProduct)

  // CÁCH VIẾT EXPLICIT MANY-TO-MANY (nếu cần thêm fields vào bảng junction):
  // productsCategories ProductsCategories[]

  @@index([deletedAt]) // mục đích index trường "deletedAt" để khi query các item là null (nghĩa là chưa xoá mềm) sẽ nhanh hơn.
}

model CategoryTranslation {
  id          Int    @id @default(autoincrement())
  categoryId  Int
  languageId  String
  name        String @db.VarChar(500)
  description String

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  language Language @relation(fields: [languageId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  createdById Int?
  updatedById Int?
  deletedById Int?

  createdBy User? @relation("CategoryTranslationCreatedBy", fields: [createdById], references: [id], onDelete: SetNull, onUpdate: NoAction)
  updatedBy User? @relation("CategoryTranslationUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull, onUpdate: NoAction)
  deletedBy User? @relation("CategoryTranslationDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull, onUpdate: NoAction)

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // @@unique([categoryId, languageId], { where: { deletedAt: null } }) // Đã set trong SQL migration 20260131124838_category_add_name_and_logo
  @@index([deletedAt]) // mục đích index trường "deletedAt" để khi query các item là null (nghĩa là chưa xoá mềm) sẽ nhanh hơn.
}

model SKU {
  id        Int    @id @default(autoincrement())
  value     String @db.VarChar(500)
  price     Float
  stock     Int
  image     String
  productId Int

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  createdById Int
  updatedById Int?
  deletedById Int?

  createdBy User  @relation("SkuCreatedBy", fields: [createdById], references: [id], onDelete: Cascade, onUpdate: NoAction) // onDelete: Cascade => khi shop (user) bị xoá thì các `product` của `shop` đó cũng phải bị xoá VÀ khi `product` bị xoá thì `sku` của `product` đó cũng phải bị xoá
  updatedBy User? @relation("SkuUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull, onUpdate: NoAction)
  deletedBy User? @relation("SkuDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull, onUpdate: NoAction)

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  cartItems           CartItem[]
  productSKUSnapshots ProductSKUSnapshot[]

  // @@unique([productId, value], { where: { deletedAt: null } }) // Đã set trong SQL migration 20260201070626_refactor_product
  @@index([deletedAt]) // mục đích index trường "deletedAt" để khi query các item là null (nghĩa là chưa xoá mềm) sẽ nhanh hơn.
  @@index([productId])
}

//////////////////////////////////////////
// BRAND
//////////////////////////////////////////

model Brand {
  id   Int    @id @default(autoincrement())
  name String @default("") @db.VarChar(500)
  logo String @db.VarChar(1000)

  createdById Int?
  updatedById Int?
  deletedById Int?

  createdBy User? @relation("BrandCreatedBy", fields: [createdById], references: [id], onDelete: SetNull, onUpdate: NoAction)
  updatedBy User? @relation("BrandUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull, onUpdate: NoAction)
  deletedBy User? @relation("BrandDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull, onUpdate: NoAction)

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  products          Product[]
  brandTranslations BrandTranslation[]

  @@index([deletedAt]) // mục đích index trường "deletedAt" để khi query các item là null (nghĩa là chưa xoá mềm) sẽ nhanh hơn.
}

model BrandTranslation {
  id          Int    @id @default(autoincrement())
  brandId     Int
  languageId  String
  name        String @db.VarChar(500)
  description String

  brand    Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  language Language @relation(fields: [languageId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  createdById Int?
  updatedById Int?
  deletedById Int?

  createdBy User? @relation("BrandTranslationCreatedBy", fields: [createdById], references: [id], onDelete: SetNull, onUpdate: NoAction)
  updatedBy User? @relation("BrandTranslationUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull, onUpdate: NoAction)
  deletedBy User? @relation("BrandTranslationDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull, onUpdate: NoAction)

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // @@unique([brandId, languageId], { where: { deletedAt: null } }) // Đã set trong SQL migration 20260131125425_brand_translation_unique_brand_id_language_id_where_deleted_at_null
  @@index([deletedAt]) // mục đích index trường "deletedAt" để khi query các item là null (nghĩa là chưa xoá mềm) sẽ nhanh hơn.
}

//////////////////////////////////////////
// ORDER & CART
//////////////////////////////////////////

model CartItem {
  id       Int @id @default(autoincrement())
  quantity Int
  skuId    Int
  userId   Int

  sku  SKU  @relation(fields: [skuId], references: [id], onDelete: Cascade, onUpdate: NoAction) // onDelete: Cascade => khi sku bị xoá thì cart item trong giỏ hàng của user cũng phải bị xoá
  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId]) // mục đích index trường "userId" để khi query các item theo userId sẽ nhanh hơn.
}

model Order {
  id     Int         @id @default(autoincrement())
  userId Int
  status OrderStatus

  user User @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  createdById Int?
  updatedById Int?
  deletedById Int?

  createdBy User? @relation("OrderCreatedBy", fields: [createdById], references: [id], onDelete: SetNull, onUpdate: NoAction)
  updatedBy User? @relation("OrderUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull, onUpdate: NoAction)
  deletedBy User? @relation("OrderDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull, onUpdate: NoAction)

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // không cần price vì đã có trong SKU, nhân price với quantity để tính tổng tiền
  items    ProductSKUSnapshot[]
  products Product[] // ProductsOrders[] - Implicit many-to-many (Prisma tự động tạo bảng _ProductToOrder)

  @@index([deletedAt]) // mục đích index trường "deletedAt" để khi query các item là null (nghĩa là chưa xoá mềm) sẽ nhanh hơn.
  @@index([deletedAt, status])
}

model ProductSKUSnapshot {
  id          Int      @id @default(autoincrement())
  productName String   @db.VarChar(500)
  price       Float
  images      String[]
  skuValue    String   @db.VarChar(500)
  skuId       Int?
  orderId     Int?

  sku   SKU?   @relation(fields: [skuId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  order Order? @relation(fields: [orderId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  createdAt DateTime @default(now())
}

model Review {
  id        Int    @id @default(autoincrement())
  content   String
  rating    Int
  productId Int
  userId    Int

  product Product @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user    User    @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////////////////////////
// PAYMENT & MESSAGE
//////////////////////////////////////////

model PaymentTransaction {
  id                 Int      @id @default(autoincrement())
  gateway            String   @db.VarChar(100)
  transactionDate    DateTime @default(now())
  accountNumber      String   @db.VarChar(100)
  subAccount         String?  @db.VarChar(250)
  amountIn           Int      @default(0)
  amountOut          Int      @default(0)
  accumulated        Int      @default(0)
  code               String?  @db.VarChar(250)
  transactionContent String?  @db.Text
  referenceNumber    String?  @db.VarChar(255)
  body               String?  @db.Text

  createdAt DateTime @default(now())
}

model Message {
  id         Int    @id @default(autoincrement())
  fromUserId Int
  toUserId   Int
  content    String

  fromUser User @relation("FromUser", fields: [fromUserId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  toUser   User @relation("ToUser", fields: [toUserId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  readAt    DateTime?
  createdAt DateTime  @default(now())
}

